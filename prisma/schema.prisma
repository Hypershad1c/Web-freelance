// Domify — Prisma schema
// Postgres. Run `npx prisma migrate dev` after setting DATABASE_URL.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Locale {
  fr
  ar // Darija, written in Arabic script
  en
}

enum PropertyType {
  APARTMENT
  VILLA
  RIVAD
  PENTHOUSE
  LAND
  OFFICE
  COMMERCIAL
}

enum PropertyStatus {
  DRAFT
  PUBLISHED
  UNDER_OFFER
  SOLD
  ARCHIVED
}

enum ListingPurpose {
  SALE
  RENT
}

enum LeadSource {
  CONTACT_FORM
  PROPERTY_INQUIRY
  WHATSAPP_CLICK
  VALUATION_FORM
  SCHEDULE_VISIT
}

enum LeadStatus {
  NEW
  QUALIFIED
  VISIT_SCHEDULED
  NEGOTIATION
  WON
  LOST
}

enum LeadIntent {
  BUYING
  SELLING
}

enum AgentRole {
  ADMIN
  AGENT
}

// ---------- Auth (NextAuth credentials) ----------

model Agent {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  passwordHash  String
  role          AgentRole @default(AGENT)
  phone         String?
  avatarUrl     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  properties    Property[]
  assignedLeads Lead[]
}

// ---------- Property ----------

model Property {
  id               String         @id @default(cuid())
  slug             String         @unique
  reference        String         @unique // internal ref, e.g. DOM-0042
  type             PropertyType
  purpose          ListingPurpose @default(SALE)
  status           PropertyStatus @default(DRAFT)

  price            Int            // MAD
  surfaceM2        Int
  bedrooms         Int
  bathrooms        Int
  hasPool          Boolean        @default(false)
  hasParking       Boolean        @default(false)
  hasGarden        Boolean        @default(false)
  floor            Int?
  yearBuilt        Int?
  energyRating     String?

  neighborhoodId   String
  neighborhood     Neighborhood   @relation(fields: [neighborhoodId], references: [id])

  latitude         Float?
  longitude        Float?
  addressLine      String?

  // i18n content — one row per locale, kept simple via JSON to avoid
  // a join per field. Structure: { fr: { title, description, amenities[] }, ar: {...}, en: {...} }
  translations     Json

  images           PropertyImage[]
  floorPlanUrl     String?
  videoTourUrl     String?
  brochureUrl      String?

  soldAt           DateTime?
  daysOnMarket     Int?
  featured         Boolean        @default(false)

  agentId          String?
  agent            Agent?         @relation(fields: [agentId], references: [id])

  leads            Lead[]

  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([status, purpose])
  @@index([neighborhoodId])
}

model PropertyImage {
  id         String   @id @default(cuid())
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  url        String   // Cloudinary URL
  alt        String?
  position   Int      @default(0)
}

// ---------- City ----------

model City {
  id            String         @id @default(cuid())
  slug          String         @unique // used in URLs: /fr/casablanca/...
  name          String
  neighborhoods Neighborhood[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

// ---------- Neighborhood ----------

model Neighborhood {
  id           String     @id @default(cuid())
  slug         String     @unique
  name         String     // e.g. "Californie", "Ain Diab"
  cityId       String
  city         City       @relation(fields: [cityId], references: [id])
  translations Json       // { fr: { description, lifestyle, nearbyServices[] }, ar: {...}, en: {...} }
  avgPriceM2   Int?
  demandLevel  String?    // "high" | "medium" | "low" — simple string, not enum, for editorial flexibility
  imageUrl     String?
  properties   Property[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([cityId])
}

// ---------- Lead (feeds CRM sync later) ----------

model Lead {
  id               String      @id @default(cuid())
  fullName         String
  phone            String
  email            String?
  preferredLocale  Locale      @default(fr)

  intent           LeadIntent?
  budgetMin        Int?
  budgetMax        Int?
  neighborhoodPref String?
  propertyTypePref PropertyType?
  bedroomsPref     Int?
  moveInTimeline   String?

  source           LeadSource
  status           LeadStatus  @default(NEW)
  notes            String?

  propertyId       String?
  property         Property?   @relation(fields: [propertyId], references: [id])

  assignedAgentId  String?
  assignedAgent    Agent?      @relation(fields: [assignedAgentId], references: [id])

  // CRM sync bookkeeping — Odoo integration deferred, but the write path
  // is shaped so a sync worker can pick these up later without a schema change.
  syncedToCrm      Boolean     @default(false)
  crmLeadId        String?
  syncError        String?

  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  @@index([status])
  @@index([syncedToCrm])
}

// ---------- Blog ----------

model BlogPost {
  id           String   @id @default(cuid())
  slug         String   @unique
  translations Json     // { fr: { title, excerpt, body, metaTitle, metaDescription }, ar: {...}, en: {...} }
  coverImageUrl String?
  category     String?  // "buying" | "selling" | "taxes" | "investment" | "comparison" | "market-trends"
  published    Boolean  @default(false)
  publishedAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ---------- Testimonials ----------

model Testimonial {
  id           String   @id @default(cuid())
  clientName   String
  translations Json     // { fr: { quote }, ar: {...}, en: {...} }
  rating       Int      @default(5)
  photoUrl     String?
  videoUrl     String?
  isGoogleReview Boolean @default(false)
  featured     Boolean  @default(false)
  createdAt    DateTime @default(now())
}
